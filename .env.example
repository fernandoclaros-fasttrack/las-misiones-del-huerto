# Copia este archivo a .env.local y rellena con la config de tu proyecto Firebase
# (Firebase console > Configuración del proyecto > tus apps > SDK setup and configuration).
# Sin estas variables, la app usa un almacenamiento local de desarrollo (no persiste
# entre dispositivos) — ver src/shared/localStore.ts.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
