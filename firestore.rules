rules_version = '2';

// La app requiere login (ver MOO-24): solo la única cuenta de Firebase Auth de la
// familia, que protege tanto la pantalla de hijos como la de padres, puede leer o
// escribir el documento. Esta regla es la protección real de los datos — la
// pantalla de login por sí sola no bastaría si alguien llamara a la API de
// Firestore directamente sin pasar por la app.
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/default {
      allow read, write: if request.auth != null;
    }
  }
}
